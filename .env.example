APP_NAME="Codex"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Production: switch to mysql + DB_DATABASE=codex + DB_USERNAME=codex

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Production: redis (Horizon)

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@codex.philiprehberger.com"
MAIL_FROM_NAME="Codex"

# Sentry — leave empty in dev
SENTRY_LARAVEL_DSN=

# StopForumSpam blocklist refresh (Phase 3)
STOPFORUMSPAM_URL=https://www.stopforumspam.com/downloads/listed_ip_30_all.zip

# Turnstile / hCaptcha (Phase 3 — graduated friction)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# S3 for file uploads (Phase 6.5)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-west-2
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ClamAV for file scanning (Phase 6.5)
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
