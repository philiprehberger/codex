# Loaded automatically by `next build` (when NODE_ENV=production).
#
# NEXT_PUBLIC_* variables are baked into the client bundle at build time
# — so this file is what determines the URL the browser fetches from for
# drill-down modals and any future client-side API calls.
#
# Keep server-only secrets out of this file. CODEX_REVALIDATE_SECRETS,
# CODEX_ASSET_SIGNING_KEYS, etc. live in /var/www/codex-web/.env on the
# production host and are read by SSR at runtime — not baked in.
NEXT_PUBLIC_CODEX_API_HOST=api.codex.philiprehberger.com

# Google Analytics 4 measurement ID (shared across philiprehberger.com subdomains)
NEXT_PUBLIC_GA_ID=G-HZ8Z4XP611
