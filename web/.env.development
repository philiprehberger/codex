# Loaded automatically by `next dev` (when NODE_ENV=development).
#
# Local convention: SSR fetches go via the loopback URL with Host:
# localhost — `composer dev` brings up `php artisan serve` on
# 127.0.0.1:8000, and the same value is used as the host header for
# both server-side and client-side fetches.
NEXT_PUBLIC_CODEX_API_HOST=localhost
