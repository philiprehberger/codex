{
    "preset": "laravel",
    "rules": {
        "concat_space": { "spacing": "none" },
        "ordered_imports": { "sort_algorithm": "alpha" },
        "no_unused_imports": true,
        "single_quote": true,
        "trailing_comma_in_multiline": { "elements": ["arrays", "arguments", "parameters"] }
    }
}
